# Telegram API credentials (get from https://my.telegram.org/apps)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Optional: Telegram phone number for auto-login
TELEGRAM_PHONE=

# Download settings
DOWNLOAD_PATH=./downloads
MAX_CONCURRENT_DOWNLOADS=3

# Database
DB_PATH=./telegram_downloader.db

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs
